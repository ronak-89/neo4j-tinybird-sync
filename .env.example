# --- PostgreSQL (watermarks in public.tinybird_sync_state) ---
DB_HOST=localhost
DB_DATABASE=your_db
DB_USER=your_user
DB_PASSWORD=your_password
DB_PORT=5432
# DB_CONNECTION_TIMEOUT=30

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# --- Tinybird ---
TINYBIRD_BASE_URL=https://api.tinybird.co
TINYBIRD_TOKEN=your_tinybird_token

# --- MongoDB checkpoint (omit or use --no-checkpoint to skip) ---
MONGO_URI=mongourl
# MONGO_DB_NAME=checkpoint_db
# MONGO_CHECKPOINT_COLLECTION=neo4j_tinybird_backfill
# MONGO_CHECKPOINT_ID=neo4j_tinybird_backfill

# --- Job tuning ---
# BATCH_SIZE=500
